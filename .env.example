# Inbound Resend: Reply-To inclui +<leadId> para o webhook associar respostas ao cartão (mesmo From = consultora).
# O domínio inbound deve aceitar o mesmo prefixo local com sufixo +uuid (comportamento típico tipo Gmail).
RESEND_INBOUND_REPLY_TO=

# PDF da proposta — última página (lib/pdf/proposta-pdf.ts)
# Telefone no PDF quando o campo «contacto» no modal de orçamento está vazio.
NEXT_PUBLIC_CONSULTORA_TELEFONE_DISPLAY=
# Linha opcional de WhatsApp no mesmo bloco de contacto (texto livre).
NEXT_PUBLIC_CONSULTORA_WHATSAPP_DISPLAY=
